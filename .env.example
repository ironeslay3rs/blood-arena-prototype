# Optional — Online (relay) lockstep. Copy to `.env.local` for local dev.
# Run `npm run relay` in another terminal, then start `npm run dev`.

# WebSocket URL the browser uses to reach the relay (must match relay host/port).
NEXT_PUBLIC_NETPLAY_RELAY_URL=ws://127.0.0.1:8765

# Port for `scripts/netplay-relay.mjs` (defaults to 8765 if unset).
# NETPLAY_RELAY_PORT=8765
